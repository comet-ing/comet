{
    "name": "my-dapp",
    "version": "0.1.0",
    "description": "JS DApp",
    "private": "true",
    "dependencies": {
        "@cartesi/viem": "^2.0.0-alpha.4",
        "@deroll/app": "2.0.0-alpha.0",
        "@deroll/wallet": "https://github.com/brunomenezes/deroll/releases/download/%40deroll%2Fwallet%402.0.0-alpha.1/deroll-wallet-2.0.0-alpha.1.tgz",
        "viem": "^2"
    },
    "devDependencies": {
        "@dotenvx/dotenvx": "^1.40.0",
        "chalk": "^5.4.1",
        "esbuild": "^0.19.2",
        "shelljs": "^0.9.2"
    },
    "scripts": {
        "clean": "yarn clean:forge",
        "start": "ROLLUP_HTTP_SERVER_URL=\"http://127.0.0.1:5004\" node src/index.js",
        "build": "esbuild ./src/index.js --bundle --outfile=dist/index.js --platform=node --target=node20",
        "clean:deployments": "rm -rf contracts/deployments",
        "clean:forge": "forge clean",
        "build:contracts": "forge soldeer install && forge build contracts/src",
        "deploy:devnet:contract": "dotenvx run --env-file=.env.devnet -- node scripts/setupERC1155Contract.mjs"
    },
    "keywords": [
        "cartesi"
    ],
    "license": "MIT",
    "type": "module"
}
